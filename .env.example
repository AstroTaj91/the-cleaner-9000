# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI API Key (For AI Copywriter and general LLM tools)
OPENAI_API_KEY=your_openai_api_key

# Google APIs
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# Twilio Configuration (For Dispatch and Reviews SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Third-Party Scraper Integrations
SERPAPI_API_KEY=your_serpapi_api_key
APIFY_API_TOKEN=your_apify_api_token

# Apify actor overrides (optional — sensible defaults are used if unset)
# Indeed scraper actor id (default: misceres~indeed-scraper)
APIFY_INDEED_ACTOR=
# Facebook Groups scraper actor id (default: apify~facebook-groups-scraper)
APIFY_FB_GROUPS_ACTOR=
# Comma- or newline-separated list of PUBLIC Facebook group URLs to scan for
# hire requests (e.g. local community / buy-and-sell groups). If left empty, a
# curated GTA default list (see DEFAULT_FB_GROUP_URLS in src/lib/scrapers.ts) is used.
APIFY_FB_GROUP_URLS=

